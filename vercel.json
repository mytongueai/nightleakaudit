{
  "buildCommand": null,
  "outputDirectory": "public",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/npi-dentists.json",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, immutable" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/audit", "destination": "/audit.html" },
    { "source": "/audit-tool", "destination": "/audit.html" },
    { "source": "/audit-tool.html", "destination": "/audit.html" },
    { "source": "/leave-behind", "destination": "/leave-behind.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/terms", "destination": "/terms.html" },
    { "source": "/sms-consent", "destination": "/sms-consent.html" },
    { "source": "/support", "destination": "/support.html" },
    { "source": "/do-not-contact", "destination": "/do-not-contact.html" },
    { "source": "/report", "destination": "/report.html" },
    { "source": "/map", "destination": "/map.html" }
  ]
}
